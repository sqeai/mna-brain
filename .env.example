NEXT_PUBLIC_POSTHOG_KEY=posthog_key
NEXT_PUBLIC_POSTHOG_HOST=posthog_host
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=secret-key
ANTHROPIC_API_KEY=your_anthropic_api_key
INVEN_API_KEY=your_inven_api_key

# AWS S3 Configuration (for Files)
AWS_REGION=ap-southeast-3
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=mna-files
DATABASE_URL=postgresql://username:password@host:port/database

# Auth.js (NextAuth v5) — generate with: npx auth secret
AUTH_SECRET=your_auth_secret

# Shared secret sent as X-Api-Secret on public auth endpoints (signup,
# forget-password, reset-password). NEXT_PUBLIC_ because the browser needs to
# attach it — bot deterrent only, not real authentication.
PASSWORD_SALT_SECRET=your_api_shared_secret

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=bebas
LOG_LEVEL=DEBUG